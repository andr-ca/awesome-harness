#!/bin/bash
# ============================================================================
# Pre-push Hook: Run the test suite and enforce >=80% coverage
# ============================================================================
#
# This hook tests THIS repository (agentharness/awesome-harness) — it is
# not a generic test runner. It's installed the same way as
# prevent-trunk-commit (git config core.hooksPath .github/hooks, or
# tools/setup/harness-link.sh --with-hook), which means a consuming
# project's core.hooksPath can end up pointing here too. Unlike
# prevent-trunk-commit (a universal branch-name check, safe for any repo),
# this hook hardcodes THIS repo's own test files — running it against a
# consumer's push would test agentharness's code, not theirs, and block
# their push over tooling/coverage that has nothing to do with their
# project. See docs/operational/reviews/gpt-5.6-review-status.md, finding
# 1, for the exact reproduction of that regression.
#
# So: if the repo actually being pushed (cwd) isn't this repo, this hook
# no-ops (exit 0) instead of running agentharness's own suites against
# someone else's push. --with-hook still installs it (via the shared
# core.hooksPath), since prevent-trunk-commit's trunk-protection needs to
# come along too — but only this repo's own pushes are ever gated on
# tests/coverage.
#
# Blocks the push if any test suite fails, or if Python coverage drops
# below 80% (this repo's own CODING_GUIDELINES.md Production-tier bar —
# see patterns/testing/COVERAGE_REQUIREMENTS.md) — but only for pushes to
# this repo itself.
#
# Missing tooling (bats/pytest) fails the push rather than silently
# skipping — the point of this hook is enforcement, not a best-effort
# reminder. Install instructions are printed when something's missing.
# ============================================================================

set -euo pipefail

HOOKS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HOOK_REPO_ROOT="$(cd "$HOOKS_DIR/../.." && pwd)"

# Is the repo actually being pushed (current working directory) this repo,
# or some consumer project that merely points core.hooksPath here?
# git rev-parse --show-toplevel fails/returns empty for bare repos; fall back to
# deriving the repo root from the absolute git-dir path instead.
PUSHED_REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$PUSHED_REPO_ROOT" ]; then
    # Bare repo fallback: derive the repo root from the absolute git-dir.
    # - Normal / bare-worktree: --absolute-git-dir returns <root>/.git — use parent.
    # - Pure bare clone (git init --bare): git-dir IS the root — use it directly.
    GIT_ABS_DIR="$(git rev-parse --absolute-git-dir 2>/dev/null || true)"
    if [ -n "$GIT_ABS_DIR" ]; then
        if [[ "$GIT_ABS_DIR" == */.git ]]; then
            PUSHED_REPO_ROOT="$(cd "$GIT_ABS_DIR/.." && pwd)"
        else
            PUSHED_REPO_ROOT="$(cd "$GIT_ABS_DIR" && pwd)"
        fi
    fi
fi
git_common_dir() {
    local repo_root="$1"
    local common_dir
    common_dir="$(git -C "$repo_root" rev-parse --git-common-dir 2>/dev/null || true)"
    [ -n "$common_dir" ] || return 0
    if [[ "$common_dir" != /* ]]; then
        common_dir="$repo_root/$common_dir"
    fi
    (cd "$common_dir" 2>/dev/null && pwd -P) || true
}

# A linked worktree has a different top-level path from the primary checkout
# that owns this hook, but both point at the same common Git directory. Compare
# repository identity rather than only working-tree paths so worktree pushes
# retain the test and lock gates while unrelated consumers still no-op.
HOOK_COMMON_DIR="$(git_common_dir "$HOOK_REPO_ROOT")"
PUSHED_COMMON_DIR="$(git_common_dir "$PUSHED_REPO_ROOT")"
if [ "$PUSHED_REPO_ROOT" != "$HOOK_REPO_ROOT" ] && {
    [ -z "$HOOK_COMMON_DIR" ] ||
        [ -z "$PUSHED_COMMON_DIR" ] ||
        [ "$PUSHED_COMMON_DIR" != "$HOOK_COMMON_DIR" ]
}; then
    echo "pre-push: this push is not to agentharness itself (core.hooksPath"
    echo "is just borrowed from it) — skipping agentharness's own test suite."
    exit 0
fi

# Run checks against the branch being pushed. For the primary checkout this is
# the hook repository root; for a linked worktree it is that worktree's root.
REPO_ROOT="$PUSHED_REPO_ROOT"
cd "$REPO_ROOT"

# Strip repository-local Git environment variables so that tools invoked
# by this hook (bats, python3, pytest) behave as if launched from a plain
# shell rather than from inside an ongoing git operation. Without this, a
# caller that sets GIT_DIR / GIT_WORK_TREE / etc. (e.g. git itself when
# running hooks) would cause those vars to leak into subprocesses and
# confuse any git operations they start (wrong repo, wrong index, etc.).
# Use git rev-parse --local-env-vars for the authoritative list rather than
# a hard-coded set that would drift as Git adds new repo-local variables.
while IFS= read -r _gitvar; do
    unset "$_gitvar" 2>/dev/null || true
done < <(git rev-parse --local-env-vars 2>/dev/null || true)
unset _gitvar
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

# ----------------------------------------------------------------------------
# Branch-lock gate (multi-agent mutex)
# ----------------------------------------------------------------------------
# If another live agent session holds a lock for a branch being pushed,
# block the push before spending minutes on test suites. Owned locks (this
# session's, via AGENTHARNESS_AGENT_ID or ancestor pid) and stale locks
# pass. See patterns/multi-agent-coordination/COORDINATION.md.
# AGENTHARNESS_LOCK_BYPASS=1 skips the gate (emergencies only — say why in
# the PR). This gate only ever runs for pushes to this repo itself: the
# consumer no-op guard above has already exited for borrowed-hooksPath
# pushes.
if [ "${AGENTHARNESS_LOCK_BYPASS:-0}" != "1" ] && [ -x "$REPO_ROOT/tools/agent-lock.sh" ]; then
    while read -r _local_ref _local_sha _remote_ref _remote_sha; do
        [ -n "$_remote_ref" ] || continue
        _lock_branch="${_remote_ref#refs/heads/}"
        # Skip non-branch refs (tags, notes) — only branches are locked.
        [ "$_lock_branch" != "$_remote_ref" ] || continue
        if ! "$REPO_ROOT/tools/agent-lock.sh" check-branch "$_lock_branch" >/dev/null; then
            "$REPO_ROOT/tools/agent-lock.sh" check-branch "$_lock_branch" || true
            echo -e "${RED}✗ Push blocked: branch '$_lock_branch' is locked by another live agent session.${NC}"
            echo "  Coordinate or wait; AGENTHARNESS_LOCK_BYPASS=1 overrides in an emergency."
            exit 1
        fi
    done
    unset _local_ref _local_sha _remote_ref _remote_sha _lock_branch
fi

COVERAGE_MIN=80
FAILED=0

echo "Running pre-push checks (test suite + ${COVERAGE_MIN}%+ coverage)..."
echo ""

# ----------------------------------------------------------------------------
# Bats test suites
# ----------------------------------------------------------------------------
# .github/hooks/tests/ includes pre-push.bats, which tests this very script
# — guard against it recursively re-invoking itself forever.
export AGENTHARNESS_PRE_PUSH_RUNNING=1

if command -v bats >/dev/null 2>&1; then
    for suite in .github/hooks/tests/ tools/tests/harness-link.bats tools/tests/harness-lifecycle.bats tools/tests/generate-agents-md.bats tools/tests/generate-manifest.bats tools/tests/materialize-skill-symlinks.bats tools/tests/publish-authority.bats tools/tests/enforce-profile.bats; do
        [ -e "$suite" ] || continue
        echo "-> bats: $suite"
        if ! bats "$suite"; then
            FAILED=1
        fi
    done
else
    echo -e "${RED}✗ bats not installed — cannot run shell test suites.${NC}"
    echo "  Install: git clone --depth 1 https://github.com/bats-core/bats-core.git /tmp/bats-core && sudo /tmp/bats-core/install.sh /usr/local"
    FAILED=1
fi

echo ""

# ----------------------------------------------------------------------------
# Python unit tests with coverage gate
# ----------------------------------------------------------------------------
# New Python test suites should be added to this list as they're created.
# Third field is comma-separated for a suite that covers more than one
# module (tools/eval's tests exercise both score.py and run.py).
PYTHON_SUITES=(
    "patterns/logging:test_config_loader.py:config_loader"
    "patterns/agentic-loops:test_agent_loop.py:agent_loop"
    "tools/eval:tests:score,run"
)

if command -v python3 >/dev/null 2>&1 && python3 -m pytest --version >/dev/null 2>&1; then
    for entry in "${PYTHON_SUITES[@]}"; do
        IFS=':' read -r dir test_file modules <<< "$entry"
        [ -e "$REPO_ROOT/$dir/$test_file" ] || continue
        echo "-> pytest: $dir/$test_file (>=${COVERAGE_MIN}% coverage required)"
        cov_args=()
        IFS=',' read -ra module_list <<< "$modules"
        for module in "${module_list[@]}"; do
            cov_args+=("--cov=$module")
        done
        if ! (cd "$dir" && python3 -m pytest "$test_file" "${cov_args[@]}" --cov-branch --cov-fail-under="$COVERAGE_MIN" -q); then
            FAILED=1
        fi
    done
else
    echo -e "${RED}✗ pytest not installed — cannot run Python test suite.${NC}"
    echo "  Install: pip install pytest pytest-cov pyyaml"
    FAILED=1
fi

echo ""

if [ "$FAILED" -ne 0 ]; then
    echo -e "${RED}✗ Pre-push checks failed. Push blocked.${NC}"
    echo "Fix the failures above. Don't bypass with --no-verify — see COMMITTING_GUIDELINES.md."
    exit 1
fi

echo -e "${GREEN}✓ All pre-push checks passed (tests clean, coverage >= ${COVERAGE_MIN}%).${NC}"
exit 0
