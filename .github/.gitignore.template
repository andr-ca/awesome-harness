# ============================================================================
# COMPREHENSIVE .gitignore TEMPLATE
# ============================================================================
# Copy to your project as .gitignore and delete sections that don't apply.
#
# Policy notes (read before deleting sections):
# - Lock files (package-lock.json, yarn.lock, pnpm-lock.yaml, Gemfile.lock,
#   poetry.lock, go.sum, Cargo.lock for binaries) are COMMITTED, not ignored.
#   They pin exact dependency versions for reproducible builds.
# - Version-pin files (.nvmrc, .python-version, .ruby-version, .node-version)
#   are COMMITTED. They document the toolchain version for every contributor.
# - `.env.sample` is COMMITTED (sanitized template); `.env` and its local/
#   environment variants are NEVER committed.
#
# DO NOT commit secrets, API keys, passwords, or sensitive data!
# ============================================================================

# ============================================================================
# WORKTREES
# ============================================================================
.worktrees/
*.worktree

# ============================================================================
# IDE & EDITORS
# ============================================================================
.vscode/
*.code-workspace
.history/
.idea/
*.iml
*.iws
*.ipr
.sublime-project
.sublime-workspace
*.swp
*.swo
*~
.\#*
\#*\#
.vs/

# ============================================================================
# OPERATING SYSTEM
# ============================================================================
.DS_Store
.AppleDouble
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.directory
.nfs*

# ============================================================================
# DEPENDENCIES (installed packages — NOT lock files, see policy note above)
# ============================================================================

# Node.js
node_modules/
.npm
.eslintcache
.stylelintcache
.pnp
.pnp.js
# package-lock.json / yarn.lock / pnpm-lock.yaml are committed — do not ignore

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
ENV/
.tox/
.nox/
.pyre/
# requirements*.txt / poetry.lock / Pipfile.lock are committed — do not ignore

# Ruby
.bundle/
vendor/bundle/
# Gemfile.lock is committed — do not ignore

# Go
# go.sum and go.mod are committed — do not ignore
# vendor/ is project-specific: committed if you vendor dependencies,
# ignored if you rely on the module cache. Uncomment only if NOT vendoring:
# vendor/

# Rust
# Cargo.lock is committed for binaries; ignore only for libraries.
# Uncomment if this is a library crate:
# Cargo.lock

# Java / Gradle / Maven
.gradle/
*.class
*.jar
*.war

# PHP / Composer
# composer.lock is committed — do not ignore

# ============================================================================
# BUILD & COMPILATION OUTPUT
# ============================================================================
dist/
build/
out/
bin/
obj/
target/
*.o
*.a
*.so
*.dylib
*.dll
*.exe

# Web framework builds
.next/
.nuxt/
.docusaurus/
.vuepress/dist/

# ============================================================================
# ENVIRONMENT & SECRETS (CRITICAL!)
# ============================================================================
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
!.env.sample

# Secret files and credentials — NEVER commit
*.pem
*.key
*.crt
*.pfx
*.p12
*.p8
id_rsa*
id_dsa*
id_ed25519*
id_ecdsa*
secrets.json
credentials.json
google-credentials.json
.aws/
.gcloud/
.azure/
.kube/

# ============================================================================
# TEMPORARY & CACHE FILES
# ============================================================================
*.tmp
*.temp
*.bak
tmp/
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/

# ============================================================================
# TEST COVERAGE & CI ARTIFACTS
# ============================================================================
.coverage
