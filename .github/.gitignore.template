# ============================================================================
# LOGS
# ============================================================================
logs/
*.log

# ============================================================================
# DATABASE
# ============================================================================
*.db
*.sqlite
*.sqlite3
*.db-journal

# ============================================================================
# AGENTHARNESS
# ============================================================================
# .agentharness-profile (rigor tier) IS committed — a project's declared
# tier is repo policy, not a secret. .agentharness-publish-mode is NOT —
# it's a per-operator/per-machine grant of standing commit/push/PR
# authority to an agent reading this repo's CLAUDE.md (see CLAUDE.md's
# "Publish authority" section). Never commit it.
.agentharness-publish-mode

# ============================================================================
# VERSION PIN FILES — DO NOT IGNORE (commit these)
# ============================================================================
# .nvmrc, .python-version, .ruby-version, .node-version document the exact
# toolchain version and should be committed. Listed here only as a reminder
# not to add them above by accident.

