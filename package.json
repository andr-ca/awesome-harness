{
  "name": "agentharness-toolkit",
  "version": "0.2.1",
  "description": "Git conventions, coding guidelines, testing standards, and on-demand skills for coding agents (Claude Code, Codex) — written once, referenced everywhere.",
  "license": "MIT",
  "author": "Andrey (andr-ca)",
  "homepage": "https://andr.ca/agentharness",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andr-ca/agentharness.git"
  },
  "bugs": {
    "url": "https://github.com/andr-ca/agentharness/issues"
  },
  "bin": {
    "agentharness": "bin/cli.js"
  },
  "scripts": {
    "build:runtime": "python3 tools/runtime/build-zipapp.py --check-reproducible",
    "prepack": "npm run build:runtime && python3 tools/release/materialize-skill-symlinks.py materialize",
    "postpack": "python3 tools/release/materialize-skill-symlinks.py restore"
  },
  "files": [
    "bin/",
    "dist/agentharness.pyz",
    "runtime/python-build-standalone.lock.json",
    "templates/bootstrap/verify-runtime.mjs",
    ".claude/skills/",
    "languages/",
    "patterns/",
    "frameworks/",
    "tools/setup/harness-link.sh",
    "tools/setup/install_transaction.py",
    "tools/setup/block_installer.py",
    ".github/hooks/prevent-trunk-commit",
    ".github/hooks/pre-commit",
    ".github/hooks/pre-push",
    ".github/.gitignore.template",
    "AGENTS.md",
    "CLAUDE.md",
    "MANIFEST.md",
    "docs/INTEGRATION.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "os": [
    "linux",
    "darwin"
  ]
}
