# Dependencies
node_modules/
__pycache__/
*.pyc
*.pyo
*.egg-info/
# vendor/ and Gemfile.lock are NOT ignored here — see .github/.gitignore.template's
# policy note: lock files are committed for reproducible builds, and Go's
# vendor/ is project-specific (committed if vendoring, ignored only if not).

# Build artifacts
dist/
build/
*.o
*.a
*.so

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db
.DS_Store

# Testing
.coverage
.coverage.*
coverage/
.nyc_output/
htmlcov/
.pytest_cache/

# Temporary files
*.tmp
*.temp
.tmp/

# Tool outputs
.tool-cache/

# agentharness: per-operator publish-authority grant — never committed,
# see CLAUDE.md's "Publish authority" section
.agentharness-publish-mode

# --mode npm's durable local package copy (P0-02) — not applicable to this
# repo's own root normally, ignored for symmetry with the consumer-facing
# .github/.gitignore.template entry and local test/debug runs.
.agentharness-pkg/

# Git worktrees for isolated development branches
.worktrees/

# Agent coordination lock files (operational state, not committed)
.agentharness-locks/

# Local media workspace — drafts and assets for external posts/articles
# about this project. Personal working material, never committed.
media/
