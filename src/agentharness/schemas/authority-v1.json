{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentharness.dev/schemas/authority-v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "grants", "revoked"],
  "properties": {
    "schema_version": {"const": 1},
    "grants": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["operations"],
        "properties": {
          "operations": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "uniqueItems": true,
            "items": {
              "enum": [
                "commit",
                "push",
                "pr-create",
                "pr-merge",
                "issue-create",
                "fs-write-outside-repo",
                "external-message",
                "destructive-fs"
              ]
            }
          },
          "target": {
            "anyOf": [
              {"type": "string", "minLength": 1, "maxLength": 256},
              {"type": "null"}
            ]
          },
          "expires": {
            "anyOf": [
              {"type": "string", "minLength": 1, "maxLength": 64},
              {"type": "null"}
            ]
          },
          "granted_by": {
            "anyOf": [
              {"type": "string", "minLength": 1, "maxLength": 256},
              {"type": "null"}
            ]
          }
        }
      }
    },
    "revoked": {
      "type": "array",
      "maxItems": 256,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      }
    }
  }
}
