{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[multi-agent] active locks:' && tools/agent-lock.sh list 2>/dev/null; echo '[multi-agent] worktrees:' && git worktree list 2>/dev/null | tail -n +2; true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .github/hooks/claude-push-lock-guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/check-completion.sh --quiet"
          }
        ]
      }
    ]
  }
}
